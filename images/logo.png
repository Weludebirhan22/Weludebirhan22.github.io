<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140" width="140" height="140">

  <!-- Outer ring background -->
  <circle cx="70" cy="70" r="68" fill="#0D1F3C"/>
  <!-- Gold outer border -->
  <circle cx="70" cy="70" r="68" fill="none" stroke="#C9A84C" stroke-width="3.5"/>
  <!-- Inner decorative dashed ring -->
  <circle cx="70" cy="70" r="60" fill="none" stroke="#C9A84C" stroke-width="0.8"
          stroke-dasharray="3 2.5" opacity="0.45"/>

  <!-- ══ CHALICE ══ -->
  <!-- Cup body -->
  <path d="M42 38 Q41 60 70 65 Q99 60 98 38 Z" fill="#C9A84C"/>
  <!-- Cup inner sheen -->
  <path d="M50 39 Q49 54 63 60" fill="none" stroke="#E8C878"
        stroke-width="1.8" stroke-linecap="round" opacity="0.55"/>

  <!-- Stem -->
  <rect x="65.5" y="65" width="9" height="22" rx="2.5" fill="#C9A84C"/>

  <!-- Knot on stem -->
  <ellipse cx="70" cy="78" rx="8" ry="5" fill="#8A6520"/>
  <ellipse cx="70" cy="78" rx="8" ry="5" fill="none" stroke="#C9A84C" stroke-width="1.2"/>

  <!-- Base foot -->
  <rect x="50" y="86" width="40" height="5" rx="2.5" fill="#C9A84C"/>
  <!-- Base shadow line -->
  <rect x="53" y="90" width="34" height="1.5" rx="1" fill="#A07830" opacity="0.6"/>

  <!-- ══ CROSS above chalice ══ -->
  <rect x="66.5" y="13" width="7" height="21" rx="2" fill="#E8C878"/>
  <rect x="57" y="19.5" width="26" height="7" rx="2" fill="#E8C878"/>

  <!-- ══ BLOOD (3 drops in cup) ══ -->
  <circle cx="59" cy="54" r="3"   fill="#7B0000" opacity="0.9"/>
  <circle cx="70" cy="58" r="3.5" fill="#990000" opacity="0.95"/>
  <circle cx="81" cy="54" r="3"   fill="#7B0000" opacity="0.9"/>
  <!-- Drop highlights -->
  <circle cx="57.8" cy="52.8" r="1"  fill="white" opacity="0.35"/>
  <circle cx="68.5" cy="56.5" r="1.2" fill="white" opacity="0.35"/>
  <circle cx="79.8" cy="52.8" r="1"  fill="white" opacity="0.35"/>

  <!-- ══ LIGHT RAYS ══ -->
  <g opacity="0.18" stroke="#E8C878" stroke-width="1">
    <line x1="70" y1="52" x2="70" y2="22"/>
    <line x1="70" y1="52" x2="88" y2="26"/>
    <line x1="70" y1="52" x2="52" y2="26"/>
    <line x1="70" y1="52" x2="100" y2="40"/>
    <line x1="70" y1="52" x2="40"  y2="40"/>
  </g>

  <!-- ══ SCHOOL NAME — bottom arc ══ -->
  <path id="btmArc" d="M 10,78 A 61,61 0 0 0 130,78" fill="none"/>
  <text font-family="'Noto Sans Ethiopic',serif" font-size="8.5"
        fill="#C9A84C" font-weight="bold" letter-spacing="0.4">
    <textPath href="#btmArc" startOffset="3%">ውሉደ ብርሃን ሰ/ት/ቤት</textPath>
  </text>

  <!-- ══ CHURCH NAME — top arc ══ -->
  <path id="topArc" d="M 14,74 A 57,57 0 0 1 126,74" fill="none"/>
  <text font-family="'Noto Sans Ethiopic',serif" font-size="7.5"
        fill="#E8C878" letter-spacing="0.3" opacity="0.9">
    <textPath href="#topArc" startOffset="7%">ቅዱስ ዑራኤል ቤ/ክ — ወሊሶ</textPath>
  </text>

  <!-- ══ YEAR badge (center bottom of base) ══ -->
  <text x="70" y="104" text-anchor="middle"
        font-family="serif" font-size="7" fill="#A07830"
        font-weight="bold" letter-spacing="0.5">2019</text>

</svg>
